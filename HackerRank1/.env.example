# Copia este archivo como .env y reemplaza TU_* con tus valores reales.
# NUNCA subas .env a GitHub.

# Base de datos (Supabase — Session pooler, sin password en la URL)
CONNECTION_STRING=Host=TU_HOST_POOLER.supabase.com;Port=5432;Database=postgres;Username=postgres.TU_PROJECT_REF;SSL Mode=Require;Trust Server Certificate=true
DB_PASSWORD=TU_PASSWORD_SUPABASE

# JWT
JWT_SECRET_KEY=TU_CLAVE_SECRETA_JWT_MIN_32_CARACTERES
JWT_ISSUER=TU_JWT_ISSUER
JWT_AUDIENCE=TU_DOMINIO_API

# CORS (origenes separados por coma)
CORS_ORIGINS=http://localhost:5173,TU_URL_FRONTEND

# Monster ASP — deploy (GitHub Actions Secrets)
WEBSITE_NAME=TU_SITE_NAME
SERVER_COMPUTER_NAME=TU_SERVIDOR.siteasp.net
SERVER_USERNAME=TU_USUARIO_WEBDEPLOY
SERVER_PASSWORD=TU_PASSWORD_WEBDEPLOY

# Entorno local
ASPNETCORE_ENVIRONMENT=Development
